generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Conversation {
  id                   String   @id @default(cuid())
  intercomId           String   @unique
  language             String?
  languagesAll         String?
  scorePct             Int?
  label                String?
  emoji                String?
  communicationStyle   String?
  arc                  String?
  conversion           String?
  conversionDeltaPct   Int?
  scoreStartPct        Int?
  scoreEndPct          Int?
  churnRisk            String?
  churnSignals         String?
  burstCount           Int?
  confidence           Float?
  culturalCalibration  String?
  keySignalSummary     String?
  explicitCsatPct      Int?
  implicitCsatGap      Boolean  @default(true)
  agentId              String?
  teamId               String?
  analyzedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  messageScores        MessageScore[]
}

model MessageScore {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  messageIndex   Int
  role           String
  language       String?
  scorePct       Int
  confidence     Float?
  signalsJson    Json?
  timestamp      DateTime?
}

model DailySnapshot {
  id                           String   @id @default(cuid())
  date                         DateTime @unique
  avgScorePct                  Float
  totalConversations           Int
  distributionJson             Json
  styleBreakdownJson           Json
  languageBreakdownJson        Json
  conversionCount              Int
  churnCount                   Int
  explicitImplicitAgreementPct Float?
  createdAt                    DateTime @default(now())
}
