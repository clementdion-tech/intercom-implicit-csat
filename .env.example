# Intercom
INTERCOM_ACCESS_TOKEN=your_intercom_access_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (Supabase) - see SUPABASE_SETUP.md
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:5432/postgres

# Server
PORT=3000
NODE_ENV=development

# Security
CANVAS_WEBHOOK_SECRET=your_intercom_canvas_webhook_secret
DASHBOARD_ORIGIN=*

# Slack alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Batch processing
BATCH_CONCURRENCY=5
SCHEDULE_CRON=*/30 * * * *

# Dashboard (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
